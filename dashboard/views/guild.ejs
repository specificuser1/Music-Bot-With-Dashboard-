<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= guild.name %> - Music Bot Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0a0a0f;
            --bg-secondary: #12121a;
            --bg-tertiary: #1a1a26;
            --accent-primary: #00ff88;
            --accent-secondary: #00ccff;
            --text-primary: #ffffff;
            --text-secondary: #a0a0b0;
            --border-color: #2a2a38;
        }

        body {
            font-family: 'DM Mono', monospace;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 2rem 0;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 2rem;
        }

        .guild-header {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .guild-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: var(--bg-tertiary);
        }

        .guild-name {
            font-family: 'Syne', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
        }

        .back-btn {
            padding: 0.75rem 1.5rem;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
            text-decoration: none;
            transition: all 0.3s;
        }

        .back-btn:hover {
            background: var(--bg-secondary);
            border-color: var(--accent-primary);
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }

        .card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2rem;
        }

        .card-title {
            font-family: 'Syne', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: var(--accent-primary);
        }

        .now-playing {
            display: flex;
            gap: 1.5rem;
            align-items: flex-start;
        }

        .track-thumbnail {
            width: 120px;
            height: 120px;
            border-radius: 8px;
            object-fit: cover;
            border: 2px solid var(--accent-primary);
        }

        .track-info h3 {
            font-family: 'Syne', sans-serif;
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }

        .track-info p {
            color: var(--text-secondary);
            margin-bottom: 0.25rem;
        }

        .queue-list {
            max-height: 400px;
            overflow-y: auto;
        }

        .queue-item {
            display: flex;
            gap: 1rem;
            padding: 1rem;
            background: var(--bg-tertiary);
            border-radius: 8px;
            margin-bottom: 0.75rem;
            transition: all 0.3s;
        }

        .queue-item:hover {
            background: var(--bg-primary);
            transform: translateX(5px);
        }

        .queue-item img {
            width: 50px;
            height: 50px;
            border-radius: 4px;
            object-fit: cover;
        }

        .queue-item-info {
            flex: 1;
        }

        .queue-item-title {
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .queue-item-author {
            color: var(--text-secondary);
            font-size: 0.85rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .stat-box {
            background: var(--bg-tertiary);
            padding: 1.5rem;
            border-radius: 8px;
            text-align: center;
        }

        .stat-value {
            font-family: 'Syne', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            color: var(--accent-primary);
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-secondary);
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 0.75rem;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
            font-family: 'DM Mono', monospace;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--accent-primary);
        }

        .toggle-switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 24px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: var(--bg-tertiary);
            transition: 0.4s;
            border-radius: 24px;
            border: 1px solid var(--border-color);
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: 0.4s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: var(--accent-primary);
        }

        input:checked + .slider:before {
            transform: translateX(26px);
        }

        .btn-save {
            width: 100%;
            padding: 1rem;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            border: none;
            border-radius: 8px;
            color: var(--bg-primary);
            font-family: 'DM Mono', monospace;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 255, 136, 0.3);
        }

        .history-list {
            max-height: 300px;
            overflow-y: auto;
        }

        .history-item {
            padding: 1rem;
            background: var(--bg-tertiary);
            border-radius: 8px;
            margin-bottom: 0.75rem;
        }

        .history-item-title {
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .history-item-meta {
            color: var(--text-secondary);
            font-size: 0.85rem;
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
            color: var(--text-secondary);
        }

        .empty-state-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        @media (max-width: 1024px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .now-playing {
                flex-direction: column;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="guild-header">
                <% if (guild.icon) { %>
                    <img src="<%= guild.icon %>" alt="<%= guild.name %>" class="guild-icon">
                <% } %>
                <div class="guild-name"><%= guild.name %></div>
            </div>
            <a href="/dashboard" class="back-btn">← Back to Servers</a>
        </header>

        <div class="stats-grid">
            <div class="stat-box">
                <div class="stat-value"><%= stats.totalPlayed %></div>
                <div class="stat-label">Total Songs Played</div>
            </div>
            <div class="stat-box">
                <div class="stat-value"><%= settings.volume %>%</div>
                <div class="stat-label">Default Volume</div>
            </div>
        </div>

        <div class="dashboard-grid">
            <div>
                <!-- Now Playing Card -->
                <div class="card">
                    <h2 class="card-title">🎵 Now Playing</h2>
                    <% if (queue && queue.currentTrack) { %>
                        <div class="now-playing">
                            <img src="<%= queue.currentTrack.thumbnail %>" alt="<%= queue.currentTrack.title %>" class="track-thumbnail">
                            <div class="track-info">
                                <h3><%= queue.currentTrack.title %></h3>
                                <p><strong>Artist:</strong> <%= queue.currentTrack.author %></p>
                                <p><strong>Duration:</strong> <%= queue.currentTrack.duration %></p>
                                <p><strong>Requested by:</strong> <%= queue.currentTrack.requestedBy %></p>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <div class="empty-state-icon">🎵</div>
                            <p>Nothing is playing right now</p>
                        </div>
                    <% } %>
                </div>

                <!-- Queue Card -->
                <div class="card" style="margin-top: 2rem;">
                    <h2 class="card-title">📜 Queue</h2>
                    <% if (queue && queue.tracks && queue.tracks.length > 0) { %>
                        <div class="queue-list">
                            <% queue.tracks.forEach((track, index) => { %>
                                <div class="queue-item">
                                    <img src="<%= track.thumbnail %>" alt="<%= track.title %>">
                                    <div class="queue-item-info">
                                        <div class="queue-item-title"><%= index + 1 %>. <%= track.title %></div>
                                        <div class="queue-item-author"><%= track.author %> • <%= track.duration %></div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <div class="empty-state-icon">📜</div>
                            <p>Queue is empty</p>
                        </div>
                    <% } %>
                </div>

                <!-- History Card -->
                <div class="card" style="margin-top: 2rem;">
                    <h2 class="card-title">📜 Recently Played</h2>
                    <% if (history && history.length > 0) { %>
                        <div class="history-list">
                            <% history.forEach(item => { %>
                                <div class="history-item">
                                    <div class="history-item-title"><%= item.track_title %></div>
                                    <div class="history-item-meta">
                                        Played by User <%= item.user_id %> • <%= new Date(item.played_at * 1000).toLocaleString() %>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <p>No history yet</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <div>
                <!-- Settings Card -->
                <div class="card">
                    <h2 class="card-title">⚙️ Server Settings</h2>
                    <form id="settingsForm">
                        <div class="form-group">
                            <label for="prefix">Command Prefix</label>
                            <input type="text" id="prefix" name="prefix" value="<%= settings.prefix %>" maxlength="5">
                        </div>

                        <div class="form-group">
                            <label for="volume">Default Volume (0-100)</label>
                            <input type="number" id="volume" name="volume" value="<%= settings.volume %>" min="0" max="100">
                        </div>

                        <div class="form-group">
                            <label>Announce Songs</label>
                            <label class="toggle-switch">
                                <input type="checkbox" id="announce_songs" name="announce_songs" <%= settings.announce_songs ? 'checked' : '' %>>
                                <span class="slider"></span>
                            </label>
                        </div>

                        <button type="submit" class="btn-save">💾 Save Settings</button>
                    </form>
                </div>

                <!-- Top Contributors Card -->
                <div class="card" style="margin-top: 2rem;">
                    <h2 class="card-title">🏆 Top Contributors</h2>
                    <% if (stats.topUsers && stats.topUsers.length > 0) { %>
                        <% stats.topUsers.forEach((user, index) => { %>
                            <div class="history-item">
                                <div class="history-item-title">#<%= index + 1 %> User <%= user.user_id %></div>
                                <div class="history-item-meta"><%= user.count %> songs played</div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="empty-state">
                            <p>No data yet</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Handle settings form submission
        document.getElementById('settingsForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = {
                prefix: document.getElementById('prefix').value,
                volume: parseInt(document.getElementById('volume').value),
                announce_songs: document.getElementById('announce_songs').checked
            };

            try {
                const response = await fetch('/api/guild/<%= guildId %>/settings', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });

                if (response.ok) {
                    alert('Settings saved successfully!');
                    location.reload();
                } else {
                    alert('Failed to save settings');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error saving settings');
            }
        });

        // Auto-refresh queue every 10 seconds
        setInterval(() => {
            location.reload();
        }, 10000);
    </script>
</body>
</html>
