# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Dashboard Configuration
DASHBOARD_PORT=3000
CALLBACK_URL=http://localhost:3000/callback
SESSION_SECRET=your_random_secret_key_here

# MongoDB (Optional - uses SQLite by default)
MONGODB_URI=mongodb://localhost:27017/musicbot

# Bot Configuration
PREFIX=!
OWNER_ID=your_discord_id_here

# Railway Configuration (Auto-detected)
# PORT will be set automatically by Railway
# RAILWAY_STATIC_URL will be set automatically

# Optional: Spotify API (for better music search)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
